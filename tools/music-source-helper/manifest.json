{
  "manifest_version": 3,
  "name": "Shizuki Music Source Helper",
  "version": "0.1.0",
  "description": "Capture whitelisted music provider cookies for one-click binding.",
  "permissions": ["cookies", "storage"],
  "host_permissions": [
    "https://music.163.com/*",
    "https://*.music.163.com/*",
    "https://y.qq.com/*",
    "https://*.y.qq.com/*",
    "https://www.kugou.com/*",
    "https://*.kugou.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "https://shizuki.site/*",
        "https://*.shizuki.site/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
