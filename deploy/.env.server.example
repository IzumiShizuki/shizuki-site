# Minimal server-side compose env for shizuki-site.
# Copy to deploy/.env.server and adjust values for your server.

SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080
BACKEND_PORT=8080
SITE_PORT=5173

# Frontend build-time settings. Changes require rebuilding the `site` image.
VITE_GATEWAY_BASE_URL=/
VITE_METING_CONSOLE_URL=
# Required by the tldraw SDK for HTTPS production deployments.
# Put the issued public, domain-bound key in deploy/.env.server only.
VITE_TLDRAW_LICENSE_KEY=

# Optional AI chat overrides.
AI_CHAT_ENABLED=false
AI_CHAT_BASE_URL=
AI_CHAT_API_KEY=
AI_CHAT_MODEL=cpa-gpt-5.4-mini

# Blog sidecars.
PRESENTATION_GENERATOR_PORT=3210
VIDEO_CONVERTER_PORT=3220

# Light-app balance bill sync sidecar.
BILL_SYNC_AGENT_PORT=39031
BILL_SYNC_AGENT_TOKEN=
BILL_SYNC_AGENT_HEADLESS=true
BILL_SYNC_AGENT_BROWSER_PATH=
BILL_SYNC_AGENT_TIMEOUT_MS=45000
BILL_SYNC_AGENT_NAV_TIMEOUT_MS=60000
BILL_SYNC_AGENT_TIMEZONE=Asia/Shanghai
BILL_SYNC_AGENT_ALIPAY_LOGIN_URL=
BILL_SYNC_AGENT_ALIPAY_BILL_URL=
BILL_SYNC_AGENT_DATA_DIR=/opt/shizuki-site/data/bill-sync-agent
BILL_SYNC_AGENT_WECHAT_BILL_DIR=/data/wechat-bills
BILL_SYNC_AGENT_BANKCARD_BILL_DIR=/data/bankcard-bills

# Notion MCP sidecar.
NOTION_MCP_PORT=39051
NOTION_MCP_ENDPOINT_PATH=/mcp/notion
NOTION_MCP_HEALTH_PATH=/healthz
NOTION_MCP_PREFERRED_SOURCE=blog
# Generate once: openssl rand -base64 32
NOTION_MCP_SERVER_TOKEN=

# Backend uses this via resouces/yaml/common-config.yaml placeholder.
# Generate once: openssl rand -base64 32
BALANCE_STORAGE_STATE_ENCRYPTION_KEY=<GENERATE_BASE64_32_BYTES>
