# Shizuki AI -> new-api (CPA source) example
# Current intended route:
#   monolith-app -> new-api -> CPA -> upstream Codex models
#
# If your app is deployed on the same server but not through the public domain,
# replace AI_CHAT_BASE_URL with an internal address that can reach new-api.

AI_CHAT_ENABLED=true
AI_CHAT_BASE_URL=https://api.shizuki.online
AI_CHAT_API_KEY=sk-REPLACE_WITH_YOUR_NEW_API_TOKEN
AI_CHAT_MODEL=cpa-gpt-5.4-mini

# Optional tuning
AI_CHAT_SYSTEM_PROMPT=
AI_CHAT_CONNECT_TIMEOUT_MS=2500
AI_CHAT_READ_TIMEOUT_MS=90000
AI_CHAT_MAX_TOKENS=800
AI_CHAT_MAX_CONTEXT_MESSAGES=12
AI_CHAT_MAX_WORLDBOOK_ENTRIES=8
AI_CHAT_TEMPERATURE=0.7
