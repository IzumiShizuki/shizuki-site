# ---------- runtime ----------
MEMORYOS_PORT=8788
MEMORYOS_REF=8688d5128901a88a70a3ba961de8705a6cdab4c0
MEMORYOS_HF_ENDPOINT=https://hf-mirror.com

# ---------- upstream llm ----------
# Recommended on server: use the local new-api gateway.
MEMORYOS_OPENAI_BASE_URL=http://host.docker.internal:3000/v1
MEMORYOS_OPENAI_API_KEY=CHANGE_ME_MEMORYOS_NEWAPI_TOKEN
MEMORYOS_LLM_MODEL=gpt-4o-mini

# ---------- memoryos tuning ----------
MEMORYOS_DEFAULT_ASSISTANT_ID=shizuki_memory
# After running deploy/prefetch_memoryos_model.sh on the server, switch this to:
# /var/lib/memoryos/models/all-MiniLM-L6-v2
MEMORYOS_EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
MEMORYOS_SHORT_TERM_CAPACITY=6
MEMORYOS_MID_TERM_CAPACITY=2000
MEMORYOS_LONG_TERM_KNOWLEDGE_CAPACITY=100
MEMORYOS_RETRIEVAL_QUEUE_CAPACITY=7
MEMORYOS_MID_TERM_HEAT_THRESHOLD=5.0
MEMORYOS_MID_TERM_SIMILARITY_THRESHOLD=0.6
MEMORYOS_DEFAULT_JOURNAL_LIMIT=20
