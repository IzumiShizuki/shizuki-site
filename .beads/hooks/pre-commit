#!/usr/bin/env sh
# bd-shim v1
# bd-hooks-version: 0.52.0
#
# bd (beads) pre-commit hook
#
# Export the Dolt-backed issue database to JSONL and stage the tracked
# artifact. The bundled bd hook currently emits a generic export warning in
# this repository even when direct export succeeds, so keep the local hook to
# the two operations this project needs before commit.

# Check if bd is available
if ! command -v bd >/dev/null 2>&1; then
    echo "Warning: bd command not found in PATH, skipping pre-commit hook" >&2
    echo "  Install bd: brew install beads" >&2
    echo "  Or add bd to your PATH" >&2
    exit 0
fi

if ! bd export -o .beads/issues.jsonl >/dev/null 2>&1; then
    echo "Warning: bd export failed, skipping issue JSONL staging" >&2
    exit 0
fi

if ! git add -- .beads/issues.jsonl >/dev/null 2>&1; then
    echo "Warning: could not stage .beads/issues.jsonl after bd export" >&2
    exit 0
fi

exit 0
