FROM m.daocloud.io/mcr.microsoft.com/playwright:v1.58.2-noble

WORKDIR /app

ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

COPY tools/presentation-generator/package.json ./package.json
COPY tools/presentation-generator/package-lock.json ./package-lock.json
RUN npm ci

COPY tools/presentation-generator/server.mjs ./server.mjs

ENV NODE_ENV=production
ENV PORT=3210

EXPOSE 3210

CMD ["npm", "run", "start"]
